{
  "compilerOptions": {
    "esModuleInterop": true,
    "paths": {
      "@root/*": [
        "src/*"
      ],
      "@app/*": [
        "src/app/*"
      ],
      "@store/*": [
        "src/app/store/*"
      ],
       "@features/*": [
        "src/features/*"
      ],
      "@routes/*": [
        "src/app/routes/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@entities/*": [
        "src/entities/*"
      ], 
      "@pages/*": [
        "src/pages/*"
      ]
    }
  }
}